# Copy this file to .env and fill in your values before deploying

# Port the Express server listens on (AWS/EC2 typically uses 3001 or 8080)
PORT=3001

# The full URL of your deployed frontend (used to restrict CORS in production)
# Example: https://campaign-manager.yourdomain.com
ALLOWED_ORIGIN=http://localhost:3000

# Base URL for landing page links embedded in campaign emails.
# In development this is the local Vite server; in production set it
# to your deployed frontend URL so email CTA buttons work correctly.
LANDING_BASE_URL=http://localhost:3000
